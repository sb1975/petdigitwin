# PetDigiTwin Environment Variables
# Copy this to .env and fill in your actual values

# MongoDB Connection
# For MongoDB Atlas: mongodb+srv://user:password@cluster.mongodb.net/petdigitwin?retryWrites=true&w=majority
# For local: mongodb://localhost:27017/petdigitwin
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/petdigitwin?retryWrites=true&w=majority

# Google Generative AI API Key
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_MODEL=gemini-2.5-flash

# Gemini Enterprise Agent Platform SDK mode (Vertex AI)
# Set USE_VERTEX_SDK=true to use Vertex SDK instead of direct Gemini API key path.
USE_VERTEX_SDK=false
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Elastic (optional for next phase)
ELASTICSEARCH_URL=https://your-project.es.us-central1.gcp.elastic.cloud:443
ELASTICSEARCH_API_KEY=your-elasticsearch-api-key

# Arize Phoenix (optional for next phase)
PHOENIX_API_KEY=your-phoenix-api-key
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/s/your-space
ENABLE_ARIZE_TRACING=true
OTEL_SERVICE_NAME=petdigitwin-agent
PHOENIX_PROJECT_NAME=petdigitwin-mvp

# Optional: Flask settings
# FLASK_ENV=development
# DEBUG=False
